from signalfx.detectors.autodetect import utils
from signalfx.detectors.apm.errors.sudden_change_v2 import sudden_change as errors_sudden_change_v2


def error_rate_sudden_change_detector(current_window: duration = duration('10m'),
                                      preceding_window: duration = duration('1h'),
                                      fire_growth_threshold_perc: float = 100,
                                      clear_growth_threshold_perc: float = 80,
                                      filter_: filter = None,
                                      attempt_threshold: float = 10):
    # :param current_window label=Current window
    # :param current_window description=Window being tested for high error rate
    # :param preceding_window label=Historical window
    # :param preceding_window description=Window that defines normal error rate
    # :param fire_growth_threshold_perc label=Trigger threshold
    # :param fire_growth_threshold_perc description=Trigger the alert when the current value is more than this percentage above the historical norm
    # :param fire_growth_threshold_perc min=0
    # :param fire_growth_threshold_perc max=100
    # :param fire_growth_threshold_perc unit=%
    # :param clear_growth_threshold_perc label=Clear threshold
    # :param clear_growth_threshold_perc description=Clear the alert when the current value is less than this percentage above the historical norm; must be lower than trigger threshold.
    # :param clear_growth_threshold_perc min=0
    # :param clear_growth_threshold_perc max=100
    # :param clear_growth_threshold_perc unit=%
    # :param filter_ metric_name=service.request.count
    # :param filter_ dimensions=deployment.environment,service.name
    # :param attempt_threshold label=Minimum request volume
    # :param attempt_threshold description=Minimum number of requests in current window; prevents alerts for sparse data.
    # :param attempt_threshold round_to=0
    # :viz valueSuffix=%
    # :return: detect block that triggers when error ratio grows by a specified amount
    fire_growth_threshold_rate = fire_growth_threshold_perc * 0.01
    clear_growth_threshold_rate = clear_growth_threshold_perc * 0.01
    return errors_sudden_change_v2.detector(current_window=current_window, preceding_window=preceding_window,
                                            fire_growth_threshold=fire_growth_threshold_rate,
                                            clear_growth_threshold=clear_growth_threshold_rate,
                                            filter_=filter_, attempt_threshold=attempt_threshold,
                                            resource_type='service', auto_resolve_after=utils.AUTO_RESOLVE_AFTER)


def blended(guard: float = 30, headroom: float = 1.5, filter_: filter = None):
    # Detect when error rate increases, compared to historical error rates
    # :param guard label=Heuristic floor (errors per second)
    # :param guard description=Don't alert for error rates under this.
    # :param headroom label=Headroom multiplier (unitless; usually between 1.2 and 2.0)
    # :param headroom description=How much worse error rate must be, compared to historical, in order to trigger an alert.
    # :param filter_ label=Additional filter
    # :param filter_ description=Optionally refine the set of observed entities with an additional filter.
    # :param filter_ metric_name=service.request
    # :return: detect block that triggers when error rate increases
    diagnostics = False  # setting this to True breaks the autodetectors UI
    if filter_ is None:
        _filter = filter('sf_error', 'true')
    else:
        _filter = filter_ and filter('sf_error', 'true')
    by_ = ['sf_service', 'sf_environment']
    errors = histogram('service.request', filter=_filter, resolution='1s').count(over='1s').rate(by=by_).publish('Error Rate')
    errors_today = errors.percentile(pct=80, over='12h').publish('Today', enable=diagnostics)
    errors_yesterday = errors.timeshift('23h').percentile(pct=80, over='2h').publish('Yesterday', enable=diagnostics)
    errors_weekago = errors_yesterday.timeshift('6d').publish('Week Ago', enable=diagnostics)
    alert_level = max(max(errors_today, errors_yesterday, errors_weekago) * headroom, guard)
    ann = [annotate(alert_level, 'upper fire threshold', {
        'sfui_streamType': 'threshold','sfui_state':'fire','sfui_orientation':'above'})]
    event_ann = {'alert_type': 'errors', 'detector_type': 'apm'}
    return detect(
        on=when(errors > alert_level, lasting='15m', at_least=0.8),
        off=when(errors <= alert_level, lasting='20m', at_least=0.85),
        annotations=ann,
        event_annotations=event_ann,
        auto_resolve_after='1d',
    )


def blended_sensitivity(guard: float = 30, sensitivity: float = 0.5, filter_: filter = None):
    # Detect when error rate increases, compared to historical error rates
    # :param guard label=Minimum alert threshold
    # :param guard min=0
    # :param guard unit=eps
    # :param guard description=We won't alert for error rates under this.
    # :param sensitivity label=sensitivity
    # :param sensitivity description=Low sensitivity means less alerts, high sensitivity mean more alerts. For exemple, a sensitivity of 0.5 means the alert will trigger when error rate is 2x the historical level.
    # :param sensitivity min=0
    # :param sensitivity max=1
    # :param filter_ label=Additional filter
    # :param filter_ description=Optionally refine the set of observed entities with an additional filter.
    # :param filter_ metric_name=service.request
    # :viz valueSuffix=Hz
    # :return: detect block that triggers when error rate increases
    assert sensitivity >= 0 and sensitivity <= 1, {
        'sensitivity': sensitivity,
        'sfui_errorKeys': ['sensitivity'],
        'sfui_errorTemplate': "{{{sensitivity}}} must be in range: [0..1]"}
    headroom = 3 - 2 * sensitivity
    return blended(guard=guard, headroom=headroom, filter_=filter_)


def blendedv2(guard: float = 30, headroom: float = 1.5, filter_: filter = None, by_: list = ['sf_service', 'sf_environment'], diagnostics: bool = False):
    # Detect when error rate increases, compared to historical error rates
    # Compared to blended, this version uses a shorter time window to compute the historical p80 baselines, making it less sensitive to short recurrent spikes.
    # :param guard label=Minimum alert threshold
    # :param guard min=0
    # :param guard unit=eps
    # :param guard description=We won't alert for error rates under this.
    # :param headroom label=Headroom
    # :param headroom description=For example, a headroom of 1.5 means the alert will trigger when error rate is 1.5x the historical level.
    # :param headroom min=0
    # :param filter_ label=Additional filter
    # :param filter_ description=Optionally refine the set of observed entities with an additional filter.
    # :param filter_ metric_name=service.request
    # :param by_ label=Group-by dimensions
    # :param by_ description=Default 'sf_service' and 'sf_environment'; consider adding 'sf_operation', using 'service.name', etc.
    # :param diagnostics label=Enable explanatory plots
    # :param diagnostics description=Adds Today, Yesterday, and Week Ago percentile plots to help explain the alert; setting this to True breaks the autodetectors UI
    # :viz valueSuffix=Hz
    # :return: detect block that triggers when error rate increases
    if filter_ is None:
        _filter = filter('sf_error', 'true')
    else:
        _filter = filter_ and filter('sf_error', 'true')
    errors = histogram('service.request', filter=_filter, resolution='1s').count(over='1s').rate(by=by_).publish('Error Rate')
    errors_today = errors.percentile(pct=80, over='12h').publish('Today', enable=diagnostics)
    errors_yesterday = errors.percentile(pct=80, over='40m').timeshift('23h40m').publish('Yesterday', enable=diagnostics)
    errors_weekago = errors_yesterday.timeshift('6d').publish('Week Ago', enable=diagnostics)
    alert_level = max(max(errors_today, errors_yesterday, errors_weekago) * headroom, guard)
    ann = [annotate(alert_level, 'upper fire threshold', {
        'sfui_streamType': 'threshold','sfui_state':'fire','sfui_orientation':'above'})]
    return detect(
        on=when(errors > alert_level, lasting='15m', at_least=0.8),
        off=when(errors <= alert_level, lasting='20m', at_least=0.85),
        annotations=ann,
        auto_resolve_after='1d',
    )
